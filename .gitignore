# Local .terraform directories
**/.terraform/*

# Terraform state files — NEVER commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file (keep this if you want reproducible provider versions)
# .terraform.lock.hcl

# Terraform plan output files
*.tfplan

# SSH keys
*.pem
*.key

# macOS
.DS_Store

# Windows
Thumbs.db
